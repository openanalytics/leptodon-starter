#[generate_docs]
#[component]
pub fn SideBarLink<H>(
    #[prop(optional, into)] icon: MaybeProp<IconRef>,
    href: H,
    children: Children,
) -> impl IntoView
where
    H: ToHref + Send + Sync + 'static,
